NODE_ENV=development
PORT=4000
WEB_PORT=3000
# Production example: https://ledgerlink.asdlabs.com.ve
WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ledgerlink

GOOGLE_CLOUD_PROJECT_ID=miproyectovision-clubsams
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production example: https://ledgerlink.asdlabs.com.ve/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
GOOGLE_GMAIL_ACCOUNT=venezuelaonline2020@gmail.com
GOOGLE_APPLICATION_CREDENTIALS=

GMAIL_PUBSUB_TOPIC=projects/miproyectovision-clubsams/topics/gmail-inbox-events
GMAIL_PUBSUB_SUBSCRIPTION=projects/miproyectovision-clubsams/subscriptions/gmail-inbox-events-sub
GMAIL_PUBSUB_PULL_MAX_MESSAGES=10
GMAIL_PUBSUB_WORKER_INTERVAL_MS=15000
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SERVICE_SID=
TWILIO_VALIDATE_SIGNATURE=false
WHATSAPP_ALLOWED_TEST_NUMBERS=
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o

BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Optional receiver UID, Pay ID, email, or display name expected on Binance Pay transactions.
BINANCE_ALLOWED_RECEIVER_ID=
BINANCE_RECV_WINDOW_MS=5000
# Optional: when set, LedgerLink sends Binance checks to a private verifier
# service instead of calling Binance directly from this server.
BINANCE_VERIFIER_URL=
BINANCE_VERIFIER_TOKEN=
BINANCE_VERIFIER_TIMEOUT_MS=10000

# Required before saving InstaPago/Multibanco credentials in the web UI.
# Use a long random value in production and keep it stable.
PAYMENT_CONFIG_ENCRYPTION_KEY=
INSTAPAGO_TIMEOUT_MS=15000

APP_NAME=LedgerLink by ASD Labs
APP_OWNER=Tavox
APP_COMPANY=ASD Labs
LOG_LEVEL=info
